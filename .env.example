# Copy to .env and fill in values

# Central Bank
CENTRAL_BANK_URL=https://test.diarainfra.com/central-bank

# Your bank identity
BANK_ID=MIN001
BANK_NAME=MIN001 Branch Bank

# Public URL of this gateway (Railway will give you one)
# Example: https://gateway-production-xxxx.up.railway.app/api/v1
BANK_ADDRESS=http://localhost:3000/api/v1

# Internal service URLs
# Local Docker:
USER_SERVICE_URL=http://user-service:3001
ACCOUNT_SERVICE_URL=http://account-service:3002
TRANSFER_SERVICE_URL=http://transfer-service:3003
# Railway private networking (uncomment when deploying to Railway):
# USER_SERVICE_URL=http://user-service.railway.internal:3001
# ACCOUNT_SERVICE_URL=http://account-service.railway.internal:3002
# TRANSFER_SERVICE_URL=http://transfer-service.railway.internal:3003
